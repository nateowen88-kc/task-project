{
  "name": "task-project",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "clean": "node -e \"import fs from 'node:fs'; for (const path of ['apps/web/dist', 'server-dist', 'dist']) fs.rmSync(path, { recursive: true, force: true });\"",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "dev:client": "npm run dev:web",
    "dev:https-proxy": "node scripts/https-forward.js",
    "dev:api": "tsx watch apps/api/server/index.ts",
    "dev:server": "npm run dev:api",
    "postinstall": "prisma generate --config apps/api/prisma.config.ts",
    "build": "npm run clean && npm run build:web && npm run build:api",
    "build:web": "tsc -p apps/web/tsconfig.json && vite build --config apps/web/vite.config.ts",
    "build:api": "prisma generate --config apps/api/prisma.config.ts && tsc -p apps/api/tsconfig.server.json",
    "test": "node --import tsx --test apps/**/*.test.ts",
    "start": "node server-dist/apps/api/server/index.js",
    "preview": "vite preview --config apps/web/vite.config.ts",
    "prisma:generate": "prisma generate --config apps/api/prisma.config.ts",
    "prisma:validate": "prisma validate --config apps/api/prisma.config.ts",
    "prisma:migrate:dev": "prisma migrate dev --config apps/api/prisma.config.ts",
    "prisma:migrate:deploy": "prisma migrate deploy --config apps/api/prisma.config.ts",
    "prisma:studio": "prisma studio --config apps/api/prisma.config.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:migrate:local-to-neon": "tsx scripts/migrate-local-to-neon.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@vercel/analytics": "^2.0.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
