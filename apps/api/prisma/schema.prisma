generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  BLOCKED
  TODO
  IN_PROGRESS
  DONE
}

enum TaskImportance {
  LOW
  MEDIUM
  HIGH
}

enum RecurrenceRule {
  DAILY
  WEEKDAYS
  WEEKLY
  MONTHLY
}

enum CaptureSourceType {
  SLACK
  EMAIL
}

enum CaptureStatus {
  NEW
  ACCEPTED
  DISCARDED
}

enum WorkspaceRole {
  OWNER
  ADMIN
  USER
}

enum TaskActivityType {
  CREATED
  UPDATED
  STATUS_CHANGED
  ASSIGNEE_CHANGED
  COMMENT_ADDED
  ARCHIVED
  DELETED
}

enum NotificationType {
  TASK_ASSIGNED
  COMMENT_ADDED
  TASK_DUE
  TASK_OVERDUE
}

enum WorkspaceInviteRole {
  ADMIN
  USER
}

enum PasswordResetTokenType {
  ACCOUNT_SETUP
  PASSWORD_RECOVERY
}

enum CalendarProvider {
  OUTLOOK
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  name            String
  passwordHash    String
  isGodMode       Boolean           @default(false)
  defaultWorkspaceId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @default(now()) @updatedAt
  defaultWorkspace Workspace?       @relation("UserDefaultWorkspace", fields: [defaultWorkspaceId], references: [id], onDelete: SetNull)
  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  memberships     WorkspaceMember[]
  sessions        Session[]
  assignedTasks   Task[]            @relation("TaskAssignee")
  createdTasks    Task[]            @relation("TaskCreator")
  taskComments    TaskComment[]     @relation("TaskCommentAuthor")
  taskActivities  TaskActivity[]    @relation("TaskActivityActor")
  receivedNotifications Notification[] @relation("NotificationRecipient")
  actorNotifications    Notification[] @relation("NotificationActor")
  sentWorkspaceInvites  WorkspaceInvite[] @relation("WorkspaceInviteSender")
  passwordResetTokens   PasswordResetToken[]
  calendarConnections   CalendarConnection[]
}

model AppConfig {
  id                                 String   @id
  appBaseUrl                         String?
  resendApiKey                       String?
  resendFromEmail                    String?
  resendReplyToEmail                 String?
  emailInboundDomain                 String?
  outlookClientId                    String?
  outlookClientSecret                String?
  outlookTenantId                    String?
  slackSigningSecret                 String?
  slackDisableSignatureVerification  Boolean  @default(false)
  emailInboundToken                  String?
  createdAt                          DateTime @default(now())
  updatedAt                          DateTime @default(now()) @updatedAt
}

model CalendarConnection {
  id                   String           @id @default(cuid())
  userId               String
  provider             CalendarProvider
  externalAccountEmail String?
  accessToken          String
  refreshToken         String?
  expiresAt            DateTime
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @default(now()) @updatedAt
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([provider, expiresAt])
}

model Workspace {
  id            String            @id @default(cuid())
  name          String
  slug          String            @unique
  inboundEmailKey String          @unique
  ownerId       String?
  deactivatedAt DateTime?
  allowMemberTaskCreation Boolean @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @default(now()) @updatedAt
  owner         User?             @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  defaultUsers  User[]            @relation("UserDefaultWorkspace")
  memberships   WorkspaceMember[]
  tasks         Task[]
  occurrences   TaskOccurrence[]
  capturedItems CapturedItem[]
  taskComments  TaskComment[]
  taskActivities TaskActivity[]
  notifications Notification[]
  invites       WorkspaceInvite[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(USER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId, role])
}

model Session {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id         String                 @id @default(cuid())
  tokenHash  String                 @unique
  userId     String
  type       PasswordResetTokenType
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @default(now()) @updatedAt
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, expiresAt])
}

model Task {
  id             String           @id @default(cuid())
  workspaceId     String
  createdById     String?
  assigneeId      String?
  title          String
  details        String           @default("")
  dueDate        DateTime
  remindAt       DateTime?
  status         TaskStatus       @default(TODO)
  importance     TaskImportance   @default(MEDIUM)
  sortOrder      Int              @default(0)
  isRecurring    Boolean          @default(false)
  recurrenceRule RecurrenceRule?
  plannedForDate DateTime?
  archivedAt     DateTime?
  blockedReason  String?
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @default(now()) @updatedAt
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy      User?            @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  assignee       User?            @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  links          TaskLink[]
  occurrences    TaskOccurrence[]
  capturedItems  CapturedItem[]
  comments       TaskComment[]
  activities     TaskActivity[]
  notifications  Notification[]

  @@index([workspaceId, dueDate, status])
  @@index([workspaceId, status, sortOrder])
  @@index([workspaceId, plannedForDate, status])
  @@index([dueDate, status])
  @@index([status, sortOrder])
  @@index([plannedForDate, status])
}

model TaskLink {
  id        String   @id @default(cuid())
  taskId    String
  label     String?
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, sortOrder])
}

model TaskOccurrence {
  id           String     @id @default(cuid())
  workspaceId   String
  taskId       String
  scheduledFor DateTime
  dueDate      DateTime
  status       TaskStatus @default(TODO)
  completedAt  DateTime?
  skippedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @default(now()) @updatedAt
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  task         Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, scheduledFor])
  @@index([workspaceId, scheduledFor, status])
  @@index([scheduledFor, status])
}

model CapturedItem {
  id               String            @id @default(cuid())
  workspaceId       String
  sourceType       CaptureSourceType
  status           CaptureStatus     @default(NEW)
  externalId       String?
  title            String
  body             String            @default("")
  sourceLabel      String?
  sourceUrl        String?
  sender           String?
  suggestedDueDate DateTime?
  receivedAt       DateTime
  acceptedAt       DateTime?
  discardedAt      DateTime?
  taskId           String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @default(now()) @updatedAt
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  task             Task?             @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, receivedAt])
  @@index([workspaceId, sourceType, receivedAt])
  @@index([status, receivedAt])
  @@index([sourceType, receivedAt])
  @@unique([sourceType, externalId])
}

model TaskComment {
  id          String    @id @default(cuid())
  workspaceId String
  taskId      String
  authorId    String?
  body        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author      User?     @relation("TaskCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([taskId, createdAt])
}

model TaskActivity {
  id           String           @id @default(cuid())
  workspaceId  String
  taskId       String
  actorUserId  String?
  type         TaskActivityType
  message      String
  createdAt    DateTime         @default(now())
  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  task         Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor        User?            @relation("TaskActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([taskId, createdAt])
}

model Notification {
  id          String           @id @default(cuid())
  workspaceId String
  userId      String
  actorUserId String?
  taskId      String?
  type        NotificationType
  title       String
  body        String
  dedupeKey   String?          @unique
  readAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now()) @updatedAt
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor       User?            @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  task        Task?            @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([workspaceId, createdAt])
  @@index([taskId, createdAt])
}

model WorkspaceInvite {
  id          String              @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceInviteRole @default(USER)
  token       String              @unique
  invitedById String?
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @default(now()) @updatedAt
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy   User?               @relation("WorkspaceInviteSender", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([workspaceId, email, createdAt])
  @@index([workspaceId, expiresAt])
}
